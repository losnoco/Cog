    "GrantPathMessage" : {
      "comment" : "Message to new users regarding file permissions",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Click \"Open\" on the following folder open dialog to grant access to the specified folder. Navigate the dialog further up the folder hierarchy to grant broader access to your files. Press \"Stop warning me\" to hide any further warnings for the rest of the session."
          }
